{
    "name": "paytabs/sdk",
    "description": "Official PayTabs PHP SDK for Payment Gateway integrations",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "paytabs",
        "payment",
        "gateway",
        "sdk",
        "php"
    ],
    "support": {
        "issues": "https://github.com/paytabscom/php-sdk/issues",
        "source": "https://github.com/paytabscom/php-sdk"
    },
    "require": {
        "php": "^8.0",
        "netresearch/jsonmapper": "^5.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.90",
        "phpunit/phpunit": "^13.2"
    },
    "autoload": {
        "psr-4": {
            "Paytabs\\Sdk\\": "src/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "format": "vendor/bin/php-cs-fixer fix"
    }
}
